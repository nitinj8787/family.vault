{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<tenant-id>",
    "ClientId": "<api-application-client-id>",
    "Audience": "api://<api-application-client-id>"
  },
  "AzureStorage": {
    "AccountUri": "https://<storage-account-name>.blob.core.windows.net",
    "ContainerName": "family-vault-dev"
  },
  "AzureKeyVault": {
    "VaultUri": "https://<key-vault-name>.vault.azure.net"
  },
  "VaultUpload": {
    "MaxUploadBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg", ".txt" ]
  },
  "Document": {
    "MaxFileSizeBytes": 20971520,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg", ".txt", ".docx" ]
  }
}
