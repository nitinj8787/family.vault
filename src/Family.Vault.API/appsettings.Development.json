{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "LocalDev": {
    "Enabled": true,
    "UserId": "local-dev-user",
    "Roles": [ "PrimaryUser", "Admin" ],
    "StoragePath": "C:\\Temp\\FamilyVaultStorage"
  },
  "Sqlite": {
    "ConnectionString": "Data Source=familyvault.db"
  },
  "VaultUpload": {
    "MaxUploadBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg", ".txt" ]
  },
  "Document": {
    "MaxFileSizeBytes": 20971520,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg", ".txt", ".docx" ]
  }
}
