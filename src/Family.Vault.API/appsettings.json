{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AzureStorage": {
    "AccountUri": "https://<storage-account-name>.blob.core.windows.net",
    "ContainerName": "family-vault"
  },
  "AzureKeyVault": {
    "VaultUri": "https://<key-vault-name>.vault.azure.net"
  },
  "VaultUpload": {
    "MaxUploadBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg", ".txt" ]
  },
  "AllowedHosts": "*"
}
