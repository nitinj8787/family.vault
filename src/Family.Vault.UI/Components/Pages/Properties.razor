@page "/properties"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IPropertyApiClient PropertyApiClient
@inject ILogger<Properties> Logger
@inject ToastService Toast

<PageTitle>Property &amp; Loans – Family Vault</PageTitle>

<h1>Property &amp; Loans</h1>
<p class="vault-page-subtitle">Track your properties, ownership, and linked loans — tagged by country.</p>

@if (_isLoading)
{
    <LoadingSpinner Label="Loading properties…" />
}
else
{
    @* ── Toolbar ── *@
    <div class="vault-assets-toolbar">
        <button class="vault-btn vault-btn--primary" @onclick="OpenAddDialog">
            + Add Property
        </button>
    </div>

    @* ── Status message ── *@
    @if (_statusMessage is not null)
    {
        <StatusMessage Type="@_statusType" Message="@_statusMessage" />
    }

    @if (_properties.Count == 0)
    {
        <p class="vault-empty">No properties recorded yet. Click <strong>+ Add Property</strong> to get started.</p>
    }
    else
    {
        @* ── Grouped by country ── *@
        @foreach (var country in Enum.GetValues<PropertyCountry>())
        {
            var group = _properties.Where(p => p.Country == country).ToList();
            @if (group.Count > 0)
            {
                <section class="vault-prop-group" aria-labelledby="prop-group-@country">
                    <h2 id="prop-group-@country" class="vault-prop-group__heading">
                        <span class="vault-badge vault-badge--prop-country-@CountryCss(country)">
                            @CountryLabel(country)
                        </span>
                        <span class="vault-prop-group__count">@group.Count propert@(group.Count == 1 ? "y" : "ies")</span>
                    </h2>

                    <div class="vault-table-wrapper">
                        <table class="vault-table">
                            <thead>
                                <tr>
                                    <th>Asset Name</th>
                                    <th>Ownership</th>
                                    <th>Loan</th>
                                    <th>Documents</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prop in group)
                                {
                                    <tr class="@(prop.LoanLinked ? "vault-row--liability" : string.Empty)">
                                        <td>
                                            <strong>@prop.AssetName</strong>
                                            @if (prop.LoanLinked)
                                            {
                                                <span class="vault-badge vault-badge--liability" title="Loan linked">⚠ Liability</span>
                                            }
                                        </td>
                                        <td>@prop.Ownership</td>
                                        <td>@(prop.LoanLinked ? "Yes" : "No")</td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(prop.DocumentsLocation))
                                            {
                                                <span class="vault-muted">—</span>
                                            }
                                            else
                                            {
                                                <span title="@prop.DocumentsLocation" class="vault-doc-location">@prop.DocumentsLocation</span>
                                            }
                                        </td>
                                        <td class="vault-actions-cell">
                                            <button class="vault-btn vault-btn--secondary vault-btn--sm"
                                                    @onclick="() => OpenEditDialog(prop)">
                                                Edit
                                            </button>
                                            <button class="vault-btn vault-btn--danger vault-btn--sm"
                                                    @onclick="() => OpenDeleteConfirm(prop)">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
        }
    }
}

@* ── Add / Edit Modal ── *@
@if (_showDialog)
{
    <div class="vault-modal-overlay" role="dialog" aria-modal="true"
         aria-labelledby="prop-dialog-title">
        <div class="vault-modal">
            <div class="vault-modal__header">
                <h2 id="prop-dialog-title" class="vault-modal__title">
                    @(_editModel.IsNew ? "Add Property" : "Edit Property")
                </h2>
                <button class="vault-modal__close" @onclick="CloseDialog" aria-label="Close">✕</button>
            </div>

            <EditForm Model="_editModel" OnValidSubmit="SavePropertyAsync">
                <DataAnnotationsValidator />

                <div class="vault-form-field">
                    <label class="vault-label" for="propAssetName">
                        Asset Name <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="propAssetName" class="vault-input" @bind-Value="_editModel.AssetName"
                               placeholder="e.g. 12 Maple Street, London" />
                    <ValidationMessage For="@(() => _editModel.AssetName)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="propCountry">
                        Country <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputSelect id="propCountry" class="vault-select" @bind-Value="_editModel.Country">
                        @foreach (var country in Enum.GetValues<PropertyCountry>())
                        {
                            <option value="@country">@CountryLabel(country)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => _editModel.Country)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="propOwnership">
                        Ownership <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="propOwnership" class="vault-input" @bind-Value="_editModel.Ownership"
                               placeholder="e.g. Sole, Joint, Company" />
                    <ValidationMessage For="@(() => _editModel.Ownership)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label">
                        <InputCheckbox @bind-Value="_editModel.LoanLinked" />
                        &nbsp;Loan linked (mortgage or other liability)
                    </label>
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="propDocsLocation">Documents Location</label>
                    <InputText id="propDocsLocation" class="vault-input" @bind-Value="_editModel.DocumentsLocation"
                               placeholder="Folder path, cabinet, or online location" />
                    <ValidationMessage For="@(() => _editModel.DocumentsLocation)" class="vault-validation" />
                </div>

                <div class="vault-modal__footer">
                    <button type="button" class="vault-btn vault-btn--secondary"
                            @onclick="CloseDialog">
                        Cancel
                    </button>
                    <button type="submit" class="vault-btn vault-btn--primary"
                            disabled="@_isSaving" aria-busy="@_isSaving">
                        @(_isSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* ── Delete confirmation Modal ── *@
@if (_deleteTarget is not null)
{
    <div class="vault-modal-overlay" role="alertdialog" aria-modal="true"
         aria-labelledby="prop-delete-title">
        <div class="vault-modal vault-modal--narrow">
            <div class="vault-modal__header">
                <h2 id="prop-delete-title" class="vault-modal__title">Delete Property</h2>
            </div>
            <p>
                Are you sure you want to delete
                <strong>@_deleteTarget.AssetName</strong>?
                This action cannot be undone.
            </p>
            <div class="vault-modal__footer">
                <button class="vault-btn vault-btn--secondary" @onclick="CancelDelete">Cancel</button>
                <button class="vault-btn vault-btn--danger" @onclick="ConfirmDeleteAsync"
                        disabled="@_isSaving" aria-busy="@_isSaving">
                    @(_isSaving ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<PropertyDisplayModel> _properties = [];
    private bool _isLoading = true;
    private bool _isSaving;

    private string? _statusMessage;
    private StatusType _statusType = StatusType.Info;

    private bool _showDialog;
    private PropertyFormModel _editModel = new();
    private PropertyDisplayModel? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadPropertiesAsync();
    }

    private async Task LoadPropertiesAsync()
    {
        _isLoading = true;

        try
        {
            var items = await PropertyApiClient.GetAllAsync();
            _properties = [.. items];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load properties");
            _statusMessage = "Could not load properties. Please try again.";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Dialog helpers ──────────────────────────────────────────────────

    private void OpenAddDialog()
    {
        _editModel = new PropertyFormModel();
        _statusMessage = null;
        _showDialog = true;
    }

    private void OpenEditDialog(PropertyDisplayModel prop)
    {
        _editModel = new PropertyFormModel
        {
            Id = prop.Id,
            AssetName = prop.AssetName,
            Country = prop.Country,
            Ownership = prop.Ownership,
            LoanLinked = prop.LoanLinked,
            DocumentsLocation = prop.DocumentsLocation
        };
        _statusMessage = null;
        _showDialog = true;
    }

    private void CloseDialog()
    {
        _showDialog = false;
        _editModel = new PropertyFormModel();
    }

    // ── Save ────────────────────────────────────────────────────────────

    private async Task SavePropertyAsync()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            PropertyDisplayModel saved;

            if (_editModel.IsNew)
            {
                saved = await PropertyApiClient.AddAsync(_editModel);
                _properties.Add(saved);
                _statusMessage = $"{saved.AssetName} added successfully.";
            }
            else
            {
                saved = await PropertyApiClient.UpdateAsync(_editModel);
                var idx = _properties.FindIndex(p => p.Id == saved.Id);
                if (idx >= 0) _properties[idx] = saved;
                _statusMessage = $"{saved.AssetName} updated successfully.";
            }

            _statusType = StatusType.Success;
            _showDialog = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save property");
            _statusMessage = $"Save failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Delete ──────────────────────────────────────────────────────────

    private void OpenDeleteConfirm(PropertyDisplayModel prop)
    {
        _deleteTarget = prop;
        _statusMessage = null;
    }

    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;

        _isSaving = true;

        try
        {
            await PropertyApiClient.DeleteAsync(_deleteTarget.Id);
            _properties.RemoveAll(p => p.Id == _deleteTarget.Id);
            _statusMessage = $"{_deleteTarget.AssetName} deleted.";
            _statusType = StatusType.Success;
            _deleteTarget = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete property {PropertyId}", _deleteTarget?.Id);
            _statusMessage = $"Delete failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Label / CSS helpers ─────────────────────────────────────────────

    private static string CountryLabel(PropertyCountry country) => country switch
    {
        PropertyCountry.UK    => "🇬🇧 UK",
        PropertyCountry.India => "🇮🇳 India",
        _                     => country.ToString()
    };

    private static string CountryCss(PropertyCountry country) => country switch
    {
        PropertyCountry.UK    => "uk",
        PropertyCountry.India => "india",
        _                     => "other"
    };
}
