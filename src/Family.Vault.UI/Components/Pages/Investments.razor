@page "/investments"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IInvestmentsApiClient InvestmentsApiClient
@inject ILogger<Investments> Logger
@inject ToastService Toast

<PageTitle>Investments – Family Vault</PageTitle>

<h1>Investments</h1>
<p class="vault-page-subtitle">Track all your investment holdings — account IDs masked for security.</p>

@if (_isLoading)
{
    <LoadingSpinner Label="Loading investments…" />
}
else
{
    @* ── Toolbar ── *@
    <div class="vault-assets-toolbar">
        <button class="vault-btn vault-btn--primary" @onclick="OpenAddDialog">
            + Add Investment
        </button>
    </div>

    @* ── Status message ── *@
    @if (_statusMessage is not null)
    {
        <StatusMessage Type="@_statusType" Message="@_statusMessage" />
    }

    @if (_investments.Count == 0)
    {
        <p class="vault-empty">No investments recorded yet. Click <strong>+ Add Investment</strong> to get started.</p>
    }
    else
    {
        @* ── Summary ── *@
        <section class="vault-invest-summary" aria-label="Investment summary">
            <div class="vault-invest-summary__total">
                <span class="vault-invest-summary__count">@_investments.Count</span>
                <span class="vault-invest-summary__label">Total Holdings</span>
            </div>
            @foreach (var type in Enum.GetValues<InvestmentType>())
            {
                var count = _investments.Count(i => i.Type == type);
                @if (count > 0)
                {
                    <div class="vault-invest-summary__tile vault-invest-tile--@TypeCss(type)">
                        <span class="vault-invest-summary__count">@count</span>
                        <span class="vault-invest-summary__label">@TypeLabel(type)</span>
                    </div>
                }
            }
        </section>

        @* ── Grouped by type ── *@
        @foreach (var type in Enum.GetValues<InvestmentType>())
        {
            var group = _investments.Where(i => i.Type == type).ToList();
            @if (group.Count > 0)
            {
                <section class="vault-invest-group" aria-labelledby="group-@type">
                    <h2 id="group-@type" class="vault-invest-group__heading">
                        <span class="vault-badge vault-badge--invest-@TypeCss(type)">
                            @TypeLabel(type)
                        </span>
                        <span class="vault-invest-group__count">@group.Count holding@(group.Count == 1 ? "" : "s")</span>
                    </h2>
                    <div class="vault-table-wrapper">
                        <table class="vault-table">
                            <thead>
                                <tr>
                                    <th>Platform</th>
                                    <th>Account / Folio ID</th>
                                    <th>Nominee</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inv in group)
                                {
                                    <tr>
                                        <td><strong>@inv.Platform</strong></td>
                                        <td>
                                            <span class="vault-masked" title="Account ID is masked for security">
                                                @inv.MaskedAccountId
                                            </span>
                                        </td>
                                        <td>@(inv.Nominee ?? "—")</td>
                                        <td class="vault-actions-cell">
                                            <button class="vault-btn vault-btn--secondary vault-btn--sm"
                                                    @onclick="() => OpenEditDialog(inv)">
                                                Edit
                                            </button>
                                            <button class="vault-btn vault-btn--danger vault-btn--sm"
                                                    @onclick="() => OpenDeleteConfirm(inv)">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
        }
    }
}

@* ── Add / Edit Modal ── *@
@if (_showDialog)
{
    <div class="vault-modal-overlay" role="dialog" aria-modal="true"
         aria-labelledby="invest-dialog-title">
        <div class="vault-modal">
            <div class="vault-modal__header">
                <h2 id="invest-dialog-title" class="vault-modal__title">
                    @(_editModel.IsNew ? "Add Investment" : "Edit Investment")
                </h2>
                <button class="vault-modal__close" @onclick="CloseDialog" aria-label="Close">✕</button>
            </div>

            <EditForm Model="_editModel" OnValidSubmit="SaveInvestmentAsync">
                <DataAnnotationsValidator />

                <div class="vault-form-field">
                    <label class="vault-label" for="investPlatform">
                        Platform <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="investPlatform" class="vault-input" @bind-Value="_editModel.Platform"
                               placeholder="e.g. Vanguard, Zerodha, Coinbase" />
                    <ValidationMessage For="@(() => _editModel.Platform)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="investType">
                        Investment Type <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputSelect id="investType" class="vault-select" @bind-Value="_editModel.Type">
                        @foreach (var type in Enum.GetValues<InvestmentType>())
                        {
                            <option value="@type">@TypeLabel(type)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => _editModel.Type)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="investAccountId">
                        Account / Folio ID <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="investAccountId" class="vault-input" @bind-Value="_editModel.AccountId"
                               placeholder="Your account or folio reference"
                               autocomplete="off" />
                    <p class="vault-file-info">This will be masked in the investments list.</p>
                    <ValidationMessage For="@(() => _editModel.AccountId)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="investNominee">Nominee</label>
                    <InputText id="investNominee" class="vault-input" @bind-Value="_editModel.Nominee"
                               placeholder="Nominated beneficiary name" />
                    <ValidationMessage For="@(() => _editModel.Nominee)" class="vault-validation" />
                </div>

                <div class="vault-modal__footer">
                    <button type="button" class="vault-btn vault-btn--secondary"
                            @onclick="CloseDialog">
                        Cancel
                    </button>
                    <button type="submit" class="vault-btn vault-btn--primary"
                            disabled="@_isSaving" aria-busy="@_isSaving">
                        @(_isSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* ── Delete confirmation Modal ── *@
@if (_deleteTarget is not null)
{
    <div class="vault-modal-overlay" role="alertdialog" aria-modal="true"
         aria-labelledby="invest-delete-title">
        <div class="vault-modal vault-modal--narrow">
            <div class="vault-modal__header">
                <h2 id="invest-delete-title" class="vault-modal__title">Delete Investment</h2>
            </div>
            <p>
                Are you sure you want to delete the
                <strong>@TypeLabel(_deleteTarget.Type)</strong> holding at
                <strong>@_deleteTarget.Platform</strong>?
                This action cannot be undone.
            </p>
            <div class="vault-modal__footer">
                <button class="vault-btn vault-btn--secondary" @onclick="CancelDelete">Cancel</button>
                <button class="vault-btn vault-btn--danger" @onclick="ConfirmDeleteAsync"
                        disabled="@_isSaving" aria-busy="@_isSaving">
                    @(_isSaving ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<InvestmentDisplayModel> _investments = [];
    private bool _isLoading = true;
    private bool _isSaving;

    private string? _statusMessage;
    private StatusType _statusType = StatusType.Info;

    private bool _showDialog;
    private InvestmentFormModel _editModel = new();
    private InvestmentDisplayModel? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadInvestmentsAsync();
    }

    private async Task LoadInvestmentsAsync()
    {
        _isLoading = true;

        try
        {
            var items = await InvestmentsApiClient.GetAllAsync();
            _investments = [.. items];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load investments");
            _statusMessage = "Could not load investments. Please try again.";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Dialog helpers ──────────────────────────────────────────────────

    private void OpenAddDialog()
    {
        _editModel = new InvestmentFormModel();
        _statusMessage = null;
        _showDialog = true;
    }

    private void OpenEditDialog(InvestmentDisplayModel inv)
    {
        _editModel = new InvestmentFormModel
        {
            Id = inv.Id,
            Platform = inv.Platform,
            Type = inv.Type,
            // Account ID is masked in display model; user must re-enter to update.
            AccountId = string.Empty,
            Nominee = inv.Nominee
        };
        _statusMessage = null;
        _showDialog = true;
    }

    private void CloseDialog()
    {
        _showDialog = false;
        _editModel = new InvestmentFormModel();
    }

    // ── Save ────────────────────────────────────────────────────────────

    private async Task SaveInvestmentAsync()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            InvestmentDisplayModel saved;

            if (_editModel.IsNew)
            {
                saved = await InvestmentsApiClient.AddAsync(_editModel);
                _investments.Add(saved);
                _statusMessage = $"{TypeLabel(saved.Type)} holding at {saved.Platform} added successfully.";
            }
            else
            {
                saved = await InvestmentsApiClient.UpdateAsync(_editModel);
                var idx = _investments.FindIndex(i => i.Id == saved.Id);
                if (idx >= 0) _investments[idx] = saved;
                _statusMessage = $"{TypeLabel(saved.Type)} holding at {saved.Platform} updated successfully.";
            }

            _statusType = StatusType.Success;
            _showDialog = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save investment");
            _statusMessage = $"Save failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Delete ──────────────────────────────────────────────────────────

    private void OpenDeleteConfirm(InvestmentDisplayModel inv)
    {
        _deleteTarget = inv;
        _statusMessage = null;
    }

    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;

        _isSaving = true;

        try
        {
            await InvestmentsApiClient.DeleteAsync(_deleteTarget.Id);
            _investments.RemoveAll(i => i.Id == _deleteTarget.Id);
            _statusMessage = $"{TypeLabel(_deleteTarget.Type)} holding at {_deleteTarget.Platform} deleted.";
            _statusType = StatusType.Success;
            _deleteTarget = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete investment {InvestmentId}", _deleteTarget?.Id);
            _statusMessage = $"Delete failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Label / CSS helpers ─────────────────────────────────────────────

    private static string TypeLabel(InvestmentType type) => type switch
    {
        InvestmentType.Stocks     => "Stocks",
        InvestmentType.MutualFund => "Mutual Fund",
        InvestmentType.Pension    => "Pension",
        InvestmentType.Crypto     => "Crypto",
        _                         => type.ToString()
    };

    /// <summary>Returns a stable CSS suffix for investment-type badge colouring.</summary>
    private static string TypeCss(InvestmentType type) => type switch
    {
        InvestmentType.Stocks     => "stocks",
        InvestmentType.MutualFund => "mf",
        InvestmentType.Pension    => "pension",
        InvestmentType.Crypto     => "crypto",
        _                         => "other"
    };
}
