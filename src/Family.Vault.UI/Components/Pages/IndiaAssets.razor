@page "/india-assets"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IIndiaAssetsApiClient IndiaAssetsApiClient
@inject ILogger<IndiaAssets> Logger
@inject ToastService Toast

<PageTitle>India Assets – Family Vault</PageTitle>

<h1>India Assets</h1>
<p class="vault-page-subtitle">NRI financial assets held in India — repatriation and tax status at a glance.</p>

@if (_isLoading)
{
    <LoadingSpinner Label="Loading assets…" />
}
else
{
    @* ── Toolbar ── *@
    <div class="vault-assets-toolbar">
        <button class="vault-btn vault-btn--primary" @onclick="OpenAddDialog">
            + Add Asset
        </button>
    </div>

    @* ── Status message ── *@
    @if (_statusMessage is not null)
    {
        <StatusMessage Type="@_statusType" Message="@_statusMessage" />
    }

    @* ── Legend ── *@
    <div class="vault-india-legend">
        <span class="vault-badge vault-badge--nre">NRE</span> Fully repatriable · tax-free interest in India
        &ensp;|&ensp;
        <span class="vault-badge vault-badge--nro">NRO</span> Limited repatriation ·
        <span class="vault-badge vault-badge--taxwarn">⚠ Taxable in India</span>
    </div>

    @* ── Table ── *@
    @if (_assets.Count == 0)
    {
        <p class="vault-empty">No India assets recorded yet. Click <strong>+ Add Asset</strong> to get started.</p>
    }
    else
    {
        <div class="vault-table-wrapper">
            <table class="vault-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Bank / Platform</th>
                        <th>Account Type</th>
                        <th>Repatriation</th>
                        <th>Nominee</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in _assets)
                    {
                        <tr class="@(asset.IsTaxableInIndia ? "vault-row--risk" : "")">
                            <td>
                                <span class="vault-badge vault-badge--india-cat">
                                    @CategoryLabel(asset.Category)
                                </span>
                            </td>
                            <td>@asset.BankOrPlatform</td>
                            <td>
                                <span class="vault-badge @(asset.AccountType == NriAccountType.NRE ? "vault-badge--nre" : "vault-badge--nro")">
                                    @asset.AccountType.ToString()
                                </span>
                            </td>
                            <td>
                                <span class="vault-badge @(asset.Repatriation == RepatriationStatus.FullyRepatriable ? "vault-badge--repatriable" : "vault-badge--limited")">
                                    @RepatriationLabel(asset.Repatriation)
                                </span>
                            </td>
                            <td>@(asset.Nominee ?? "—")</td>
                            <td class="vault-india-status-cell">
                                @if (asset.IsTaxableInIndia)
                                {
                                    <span class="vault-badge vault-badge--taxwarn"
                                          title="NRO interest income is subject to TDS (Tax Deducted at Source) in India">
                                        ⚠ Taxable in India
                                    </span>
                                }
                                @if (asset.IsRepatriable)
                                {
                                    <span class="vault-badge vault-badge--repatriable"
                                          title="NRE funds (principal and interest) are freely repatriable abroad">
                                        ✓ Repatriable
                                    </span>
                                }
                            </td>
                            <td class="vault-actions-cell">
                                <button class="vault-btn vault-btn--secondary vault-btn--sm"
                                        @onclick="() => OpenEditDialog(asset)">
                                    Edit
                                </button>
                                <button class="vault-btn vault-btn--danger vault-btn--sm"
                                        @onclick="() => OpenDeleteConfirm(asset)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@* ── Add / Edit Modal ── *@
@if (_showDialog)
{
    <div class="vault-modal-overlay" role="dialog" aria-modal="true"
         aria-labelledby="india-dialog-title">
        <div class="vault-modal">
            <div class="vault-modal__header">
                <h2 id="india-dialog-title" class="vault-modal__title">
                    @(_editModel.IsNew ? "Add India Asset" : "Edit India Asset")
                </h2>
                <button class="vault-modal__close" @onclick="CloseDialog" aria-label="Close">✕</button>
            </div>

            <EditForm Model="_editModel" OnValidSubmit="SaveAssetAsync">
                <DataAnnotationsValidator />

                <div class="vault-form-field">
                    <label class="vault-label" for="indiaCategory">
                        Category <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputSelect id="indiaCategory" class="vault-select" @bind-Value="_editModel.Category">
                        @foreach (var cat in Enum.GetValues<IndiaAssetCategory>())
                        {
                            <option value="@cat">@CategoryLabel(cat)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => _editModel.Category)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="indiaPlatform">
                        Bank / Platform <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="indiaPlatform" class="vault-input" @bind-Value="_editModel.BankOrPlatform"
                               placeholder="e.g. SBI, HDFC, Zerodha, LIC" />
                    <ValidationMessage For="@(() => _editModel.BankOrPlatform)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="indiaAccountType">
                        Account Type <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputSelect id="indiaAccountType" class="vault-select"
                                 @bind-Value="_editModel.AccountType"
                                 @bind-Value:after="SyncRepatriation">
                        <option value="@NriAccountType.NRE">NRE – Non-Resident External</option>
                        <option value="@NriAccountType.NRO">NRO – Non-Resident Ordinary</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => _editModel.AccountType)" class="vault-validation" />
                    @* Inline advisory hint based on selected type *@
                    <p class="vault-india-hint @(_editModel.AccountType == NriAccountType.NRO ? "vault-india-hint--warn" : "vault-india-hint--ok")">
                        @if (_editModel.AccountType == NriAccountType.NRO)
                        {
                            <span>⚠ NRO: Interest income is <strong>taxable in India</strong>. Repatriation is limited to USD 1M/year after tax clearance.</span>
                        }
                        else
                        {
                            <span>✓ NRE: Interest is <strong>tax-free in India</strong>. Principal and interest are freely repatriable.</span>
                        }
                    </p>
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="indiaRepatriation">
                        Repatriation <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputSelect id="indiaRepatriation" class="vault-select" @bind-Value="_editModel.Repatriation">
                        <option value="@RepatriationStatus.FullyRepatriable">Fully Repatriable</option>
                        <option value="@RepatriationStatus.Limited">Limited</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => _editModel.Repatriation)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="indiaNominee">Nominee</label>
                    <InputText id="indiaNominee" class="vault-input" @bind-Value="_editModel.Nominee"
                               placeholder="Nominated beneficiary name" />
                    <ValidationMessage For="@(() => _editModel.Nominee)" class="vault-validation" />
                </div>

                <div class="vault-modal__footer">
                    <button type="button" class="vault-btn vault-btn--secondary"
                            @onclick="CloseDialog">
                        Cancel
                    </button>
                    <button type="submit" class="vault-btn vault-btn--primary"
                            disabled="@_isSaving" aria-busy="@_isSaving">
                        @(_isSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* ── Delete confirmation Modal ── *@
@if (_deleteTarget is not null)
{
    <div class="vault-modal-overlay" role="alertdialog" aria-modal="true"
         aria-labelledby="india-delete-title">
        <div class="vault-modal vault-modal--narrow">
            <div class="vault-modal__header">
                <h2 id="india-delete-title" class="vault-modal__title">Delete Asset</h2>
            </div>
            <p>
                Are you sure you want to delete the <strong>@CategoryLabel(_deleteTarget.Category)</strong>
                asset at <strong>@_deleteTarget.BankOrPlatform</strong>?
                This action cannot be undone.
            </p>
            <div class="vault-modal__footer">
                <button class="vault-btn vault-btn--secondary" @onclick="CancelDelete">Cancel</button>
                <button class="vault-btn vault-btn--danger" @onclick="ConfirmDeleteAsync"
                        disabled="@_isSaving" aria-busy="@_isSaving">
                    @(_isSaving ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<IndiaAssetDisplayModel> _assets = [];
    private bool _isLoading = true;
    private bool _isSaving;

    private string? _statusMessage;
    private StatusType _statusType = StatusType.Info;

    private bool _showDialog;
    private IndiaAssetFormModel _editModel = new();
    private IndiaAssetDisplayModel? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssetsAsync();
    }

    private async Task LoadAssetsAsync()
    {
        _isLoading = true;

        try
        {
            var items = await IndiaAssetsApiClient.GetAllAsync();
            _assets = [.. items];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load India assets");
            _statusMessage = "Could not load India assets. Please try again.";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Dialog helpers ──────────────────────────────────────────────────

    private void OpenAddDialog()
    {
        _editModel = new IndiaAssetFormModel();
        _statusMessage = null;
        _showDialog = true;
    }

    private void OpenEditDialog(IndiaAssetDisplayModel asset)
    {
        _editModel = new IndiaAssetFormModel
        {
            Id = asset.Id,
            Category = asset.Category,
            BankOrPlatform = asset.BankOrPlatform,
            AccountType = asset.AccountType,
            Repatriation = asset.Repatriation,
            Nominee = asset.Nominee
        };
        _statusMessage = null;
        _showDialog = true;
    }

    private void CloseDialog()
    {
        _showDialog = false;
        _editModel = new IndiaAssetFormModel();
    }

    /// <summary>
    /// Automatically synchronises <see cref="IndiaAssetFormModel.Repatriation"/> when
    /// <see cref="IndiaAssetFormModel.AccountType"/> changes, reflecting the regulatory
    /// rule: NRE → Fully Repatriable; NRO → Limited.
    /// </summary>
    private void SyncRepatriation()
    {
        _editModel.Repatriation = _editModel.AccountType == NriAccountType.NRE
            ? RepatriationStatus.FullyRepatriable
            : RepatriationStatus.Limited;
    }

    // ── Save ────────────────────────────────────────────────────────────

    private async Task SaveAssetAsync()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            IndiaAssetDisplayModel saved;

            if (_editModel.IsNew)
            {
                saved = await IndiaAssetsApiClient.AddAsync(_editModel);
                _assets.Add(saved);
                _statusMessage = $"Asset at {saved.BankOrPlatform} added successfully.";
            }
            else
            {
                saved = await IndiaAssetsApiClient.UpdateAsync(_editModel);
                var idx = _assets.FindIndex(a => a.Id == saved.Id);
                if (idx >= 0) _assets[idx] = saved;
                _statusMessage = $"Asset at {saved.BankOrPlatform} updated successfully.";
            }

            _statusType = StatusType.Success;
            _showDialog = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save India asset");
            _statusMessage = $"Save failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Delete ──────────────────────────────────────────────────────────

    private void OpenDeleteConfirm(IndiaAssetDisplayModel asset)
    {
        _deleteTarget = asset;
        _statusMessage = null;
    }

    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;

        _isSaving = true;

        try
        {
            await IndiaAssetsApiClient.DeleteAsync(_deleteTarget.Id);
            _assets.RemoveAll(a => a.Id == _deleteTarget.Id);
            _statusMessage = $"Asset at {_deleteTarget.BankOrPlatform} deleted.";
            _statusType = StatusType.Success;
            _deleteTarget = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete India asset {AssetId}", _deleteTarget?.Id);
            _statusMessage = $"Delete failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Label helpers ────────────────────────────────────────────────────

    private static string CategoryLabel(IndiaAssetCategory category) => category switch
    {
        IndiaAssetCategory.BankAccount  => "Bank Account",
        IndiaAssetCategory.MutualFund   => "Mutual Fund",
        IndiaAssetCategory.FixedDeposit => "Fixed Deposit",
        IndiaAssetCategory.Stocks       => "Stocks",
        IndiaAssetCategory.Property     => "Property",
        IndiaAssetCategory.Insurance    => "Insurance",
        IndiaAssetCategory.Other        => "Other",
        _                               => category.ToString()
    };

    private static string RepatriationLabel(RepatriationStatus status) => status switch
    {
        RepatriationStatus.FullyRepatriable => "Fully Repatriable",
        RepatriationStatus.Limited          => "Limited",
        _                                   => status.ToString()
    };
}
