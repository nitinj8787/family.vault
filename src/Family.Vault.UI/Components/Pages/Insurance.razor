@page "/insurance"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IInsuranceApiClient InsuranceApiClient
@inject ILogger<Insurance> Logger

<PageTitle>Insurance Manager – Family Vault</PageTitle>

<h1>Insurance Manager</h1>
<p class="vault-page-subtitle">Track policies in cards and quickly spot missing nominees.</p>

@if (_isLoading)
{
    <p class="vault-loading" role="status">Loading insurance policies…</p>
}
else
{
    <div class="vault-assets-toolbar">
        <button class="vault-btn vault-btn--primary" @onclick="OpenAddDialog">
            + Add Policy
        </button>
    </div>

    @if (_statusMessage is not null)
    {
        <StatusMessage Type="@_statusType" Message="@_statusMessage" />
    }

    @if (_policies.Count == 0)
    {
        <p class="vault-empty">No policies recorded yet. Click <strong>+ Add Policy</strong> to get started.</p>
    }
    else
    {
        <div class="vault-insurance-grid">
            @foreach (var policy in _policies)
            {
                var isMissingNominee = string.IsNullOrWhiteSpace(policy.Nominee);
                <article class="vault-insurance-card @(isMissingNominee ? "vault-insurance-card--missing-nominee" : string.Empty)">
                    <header class="vault-insurance-card__header">
                        <h2 class="vault-insurance-card__title">@policy.Provider</h2>
                        <span class="vault-badge vault-badge--insurance">@policy.PolicyType</span>
                    </header>

                    @if (isMissingNominee)
                    {
                        <div class="vault-insurance-warning" role="status">⚠ Nominee missing</div>
                    }

                    <dl class="vault-insurance-meta">
                        <dt>Policy Number</dt>
                        <dd>@policy.PolicyNumber</dd>

                        <dt>Coverage</dt>
                        <dd>@policy.Coverage</dd>

                        <dt>Nominee</dt>
                        <dd>@(isMissingNominee ? "—" : policy.Nominee)</dd>

                        <dt>Claim Contact</dt>
                        <dd>@policy.ClaimContact</dd>
                    </dl>

                    <div class="vault-actions-cell">
                        <button class="vault-btn vault-btn--secondary vault-btn--sm"
                                @onclick="() => OpenEditDialog(policy)">
                            Edit
                        </button>
                        <button class="vault-btn vault-btn--danger vault-btn--sm"
                                @onclick="() => OpenDeleteConfirm(policy)">
                            Delete
                        </button>
                    </div>
                </article>
            }
        </div>
    }
}

@if (_showDialog)
{
    <div class="vault-modal-overlay" role="dialog" aria-modal="true"
         aria-labelledby="insurance-dialog-title">
        <div class="vault-modal">
            <div class="vault-modal__header">
                <h2 id="insurance-dialog-title" class="vault-modal__title">
                    @(_editModel.IsNew ? "Add Insurance Policy" : "Edit Insurance Policy")
                </h2>
                <button class="vault-modal__close" @onclick="CloseDialog" aria-label="Close">✕</button>
            </div>

            <EditForm Model="_editModel" OnValidSubmit="SavePolicyAsync">
                <DataAnnotationsValidator />

                <div class="vault-form-field">
                    <label class="vault-label" for="insuranceProvider">
                        Provider <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="insuranceProvider" class="vault-input" @bind-Value="_editModel.Provider"
                               placeholder="e.g. HDFC Ergo, AXA, Aviva" />
                    <ValidationMessage For="@(() => _editModel.Provider)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="insurancePolicyType">
                        Policy Type <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="insurancePolicyType" class="vault-input" @bind-Value="_editModel.PolicyType"
                               placeholder="e.g. Health, Life, Vehicle" />
                    <ValidationMessage For="@(() => _editModel.PolicyType)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="insurancePolicyNumber">
                        Policy Number <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="insurancePolicyNumber" class="vault-input" @bind-Value="_editModel.PolicyNumber"
                               placeholder="Policy identifier" />
                    <ValidationMessage For="@(() => _editModel.PolicyNumber)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="insuranceCoverage">
                        Coverage <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="insuranceCoverage" class="vault-input" @bind-Value="_editModel.Coverage"
                               placeholder="Insured amount or plan details" />
                    <ValidationMessage For="@(() => _editModel.Coverage)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="insuranceNominee">Nominee</label>
                    <InputText id="insuranceNominee" class="vault-input" @bind-Value="_editModel.Nominee"
                               placeholder="Nominated beneficiary name" />
                    <ValidationMessage For="@(() => _editModel.Nominee)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="insuranceClaimContact">
                        Claim Contact <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="insuranceClaimContact" class="vault-input" @bind-Value="_editModel.ClaimContact"
                               placeholder="Phone, email, or portal details" />
                    <ValidationMessage For="@(() => _editModel.ClaimContact)" class="vault-validation" />
                </div>

                <div class="vault-modal__footer">
                    <button type="button" class="vault-btn vault-btn--secondary"
                            @onclick="CloseDialog">
                        Cancel
                    </button>
                    <button type="submit" class="vault-btn vault-btn--primary"
                            disabled="@_isSaving" aria-busy="@_isSaving">
                        @(_isSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (_deleteTarget is not null)
{
    <div class="vault-modal-overlay" role="alertdialog" aria-modal="true"
         aria-labelledby="insurance-delete-title">
        <div class="vault-modal vault-modal--narrow">
            <div class="vault-modal__header">
                <h2 id="insurance-delete-title" class="vault-modal__title">Delete Policy</h2>
            </div>
            <p>
                Are you sure you want to delete policy
                <strong>@_deleteTarget.PolicyNumber</strong> from
                <strong>@_deleteTarget.Provider</strong>?
                This action cannot be undone.
            </p>
            <div class="vault-modal__footer">
                <button class="vault-btn vault-btn--secondary" @onclick="CancelDelete">Cancel</button>
                <button class="vault-btn vault-btn--danger" @onclick="ConfirmDeleteAsync"
                        disabled="@_isSaving" aria-busy="@_isSaving">
                    @(_isSaving ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<InsuranceDisplayModel> _policies = [];
    private bool _isLoading = true;
    private bool _isSaving;

    private string? _statusMessage;
    private StatusType _statusType = StatusType.Info;

    private bool _showDialog;
    private InsuranceFormModel _editModel = new();
    private InsuranceDisplayModel? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadPoliciesAsync();
    }

    private async Task LoadPoliciesAsync()
    {
        _isLoading = true;

        try
        {
            var items = await InsuranceApiClient.GetAllAsync();
            _policies = [.. items];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load insurance policies");
            _statusMessage = "Could not load insurance policies. Please try again.";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenAddDialog()
    {
        _editModel = new InsuranceFormModel();
        _statusMessage = null;
        _showDialog = true;
    }

    private void OpenEditDialog(InsuranceDisplayModel policy)
    {
        _editModel = new InsuranceFormModel
        {
            Id = policy.Id,
            Provider = policy.Provider,
            PolicyType = policy.PolicyType,
            PolicyNumber = policy.PolicyNumber,
            Coverage = policy.Coverage,
            Nominee = policy.Nominee,
            ClaimContact = policy.ClaimContact
        };
        _statusMessage = null;
        _showDialog = true;
    }

    private void CloseDialog()
    {
        _showDialog = false;
        _editModel = new InsuranceFormModel();
    }

    private async Task SavePolicyAsync()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            InsuranceDisplayModel saved;

            if (_editModel.IsNew)
            {
                saved = await InsuranceApiClient.AddAsync(_editModel);
                _policies.Add(saved);
                _statusMessage = $"Policy from {saved.Provider} added successfully.";
            }
            else
            {
                saved = await InsuranceApiClient.UpdateAsync(_editModel);
                var idx = _policies.FindIndex(p => p.Id == saved.Id);
                if (idx >= 0) _policies[idx] = saved;
                _statusMessage = $"Policy from {saved.Provider} updated successfully.";
            }

            _statusType = StatusType.Success;
            _showDialog = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save insurance policy");
            _statusMessage = $"Save failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void OpenDeleteConfirm(InsuranceDisplayModel policy)
    {
        _deleteTarget = policy;
        _statusMessage = null;
    }

    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;

        _isSaving = true;

        try
        {
            await InsuranceApiClient.DeleteAsync(_deleteTarget.Id);
            _policies.RemoveAll(p => p.Id == _deleteTarget.Id);
            _statusMessage = $"Policy from {_deleteTarget.Provider} deleted.";
            _statusType = StatusType.Success;
            _deleteTarget = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete insurance policy {PolicyId}", _deleteTarget?.Id);
            _statusMessage = $"Delete failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }
}
