@page "/bank-accounts"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IBankAccountsApiClient BankAccountsApiClient
@inject ILogger<BankAccounts> Logger

<PageTitle>Bank Accounts – Family Vault</PageTitle>

<h1>Bank Accounts</h1>
<p class="vault-page-subtitle">All bank accounts in one place — account numbers masked for security.</p>

@if (_isLoading)
{
    <p class="vault-loading" role="status">Loading accounts…</p>
}
else
{
    @* ── Toolbar ── *@
    <div class="vault-assets-toolbar">
        <button class="vault-btn vault-btn--primary" @onclick="OpenAddDialog">
            + Add Account
        </button>
    </div>

    @* ── Status message ── *@
    @if (_statusMessage is not null)
    {
        <StatusMessage Type="@_statusType" Message="@_statusMessage" />
    }

    @* ── Table ── *@
    @if (_accounts.Count == 0)
    {
        <p class="vault-empty">No bank accounts recorded yet. Click <strong>+ Add Account</strong> to get started.</p>
    }
    else
    {
        <div class="vault-table-wrapper">
            <table class="vault-table">
                <thead>
                    <tr>
                        <th>Bank Name</th>
                        <th>Account Type</th>
                        <th>Account Number</th>
                        <th>Nominee</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var account in _accounts)
                    {
                        <tr>
                            <td><strong>@account.BankName</strong></td>
                            <td>
                                <span class="vault-badge vault-badge--bank-type-@AccountTypeCss(account.AccountType)">
                                    @AccountTypeLabel(account.AccountType)
                                </span>
                            </td>
                            <td>
                                <span class="vault-masked" title="Account number is masked for security">
                                    @account.MaskedAccountNumber
                                </span>
                            </td>
                            <td>@(account.Nominee ?? "—")</td>
                            <td class="vault-actions-cell">
                                <button class="vault-btn vault-btn--secondary vault-btn--sm"
                                        @onclick="() => OpenEditDialog(account)">
                                    Edit
                                </button>
                                <button class="vault-btn vault-btn--danger vault-btn--sm"
                                        @onclick="() => OpenDeleteConfirm(account)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@* ── Add / Edit Modal ── *@
@if (_showDialog)
{
    <div class="vault-modal-overlay" role="dialog" aria-modal="true"
         aria-labelledby="bank-dialog-title">
        <div class="vault-modal">
            <div class="vault-modal__header">
                <h2 id="bank-dialog-title" class="vault-modal__title">
                    @(_editModel.IsNew ? "Add Bank Account" : "Edit Bank Account")
                </h2>
                <button class="vault-modal__close" @onclick="CloseDialog" aria-label="Close">✕</button>
            </div>

            <EditForm Model="_editModel" OnValidSubmit="SaveAccountAsync">
                <DataAnnotationsValidator />

                <div class="vault-form-field">
                    <label class="vault-label" for="bankName">
                        Bank Name <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="bankName" class="vault-input" @bind-Value="_editModel.BankName"
                               placeholder="e.g. HDFC Bank, State Bank of India, Barclays" />
                    <ValidationMessage For="@(() => _editModel.BankName)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="bankAccountType">
                        Account Type <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputSelect id="bankAccountType" class="vault-select" @bind-Value="_editModel.AccountType">
                        @foreach (var type in Enum.GetValues<BankAccountType>())
                        {
                            <option value="@type">@AccountTypeLabel(type)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => _editModel.AccountType)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="bankAccountNumber">
                        Account Number <span class="vault-required" aria-hidden="true">*</span>
                    </label>
                    <InputText id="bankAccountNumber" class="vault-input" @bind-Value="_editModel.AccountNumber"
                               placeholder="Full account number"
                               autocomplete="off" />
                    <p class="vault-file-info">This will be masked in the table view.</p>
                    <ValidationMessage For="@(() => _editModel.AccountNumber)" class="vault-validation" />
                </div>

                <div class="vault-form-field">
                    <label class="vault-label" for="bankNominee">Nominee</label>
                    <InputText id="bankNominee" class="vault-input" @bind-Value="_editModel.Nominee"
                               placeholder="Nominated beneficiary name" />
                    <ValidationMessage For="@(() => _editModel.Nominee)" class="vault-validation" />
                </div>

                <div class="vault-modal__footer">
                    <button type="button" class="vault-btn vault-btn--secondary"
                            @onclick="CloseDialog">
                        Cancel
                    </button>
                    <button type="submit" class="vault-btn vault-btn--primary"
                            disabled="@_isSaving" aria-busy="@_isSaving">
                        @(_isSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* ── Delete confirmation Modal ── *@
@if (_deleteTarget is not null)
{
    <div class="vault-modal-overlay" role="alertdialog" aria-modal="true"
         aria-labelledby="bank-delete-title">
        <div class="vault-modal vault-modal--narrow">
            <div class="vault-modal__header">
                <h2 id="bank-delete-title" class="vault-modal__title">Delete Account</h2>
            </div>
            <p>
                Are you sure you want to delete the
                <strong>@AccountTypeLabel(_deleteTarget.AccountType)</strong> account at
                <strong>@_deleteTarget.BankName</strong>?
                This action cannot be undone.
            </p>
            <div class="vault-modal__footer">
                <button class="vault-btn vault-btn--secondary" @onclick="CancelDelete">Cancel</button>
                <button class="vault-btn vault-btn--danger" @onclick="ConfirmDeleteAsync"
                        disabled="@_isSaving" aria-busy="@_isSaving">
                    @(_isSaving ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<BankAccountDisplayModel> _accounts = [];
    private bool _isLoading = true;
    private bool _isSaving;

    private string? _statusMessage;
    private StatusType _statusType = StatusType.Info;

    private bool _showDialog;
    private BankAccountFormModel _editModel = new();
    private BankAccountDisplayModel? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccountsAsync();
    }

    private async Task LoadAccountsAsync()
    {
        _isLoading = true;

        try
        {
            var items = await BankAccountsApiClient.GetAllAsync();
            _accounts = [.. items];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load bank accounts");
            _statusMessage = "Could not load bank accounts. Please try again.";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Dialog helpers ──────────────────────────────────────────────────

    private void OpenAddDialog()
    {
        _editModel = new BankAccountFormModel();
        _statusMessage = null;
        _showDialog = true;
    }

    private void OpenEditDialog(BankAccountDisplayModel account)
    {
        _editModel = new BankAccountFormModel
        {
            Id = account.Id,
            BankName = account.BankName,
            AccountType = account.AccountType,
            // Account number is masked in the display model; user must re-enter to update.
            AccountNumber = string.Empty,
            Nominee = account.Nominee
        };
        _statusMessage = null;
        _showDialog = true;
    }

    private void CloseDialog()
    {
        _showDialog = false;
        _editModel = new BankAccountFormModel();
    }

    // ── Save ────────────────────────────────────────────────────────────

    private async Task SaveAccountAsync()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            BankAccountDisplayModel saved;

            if (_editModel.IsNew)
            {
                saved = await BankAccountsApiClient.AddAsync(_editModel);
                _accounts.Add(saved);
                _statusMessage = $"Account at {saved.BankName} added successfully.";
            }
            else
            {
                saved = await BankAccountsApiClient.UpdateAsync(_editModel);
                var idx = _accounts.FindIndex(a => a.Id == saved.Id);
                if (idx >= 0) _accounts[idx] = saved;
                _statusMessage = $"Account at {saved.BankName} updated successfully.";
            }

            _statusType = StatusType.Success;
            _showDialog = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save bank account");
            _statusMessage = $"Save failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Delete ──────────────────────────────────────────────────────────

    private void OpenDeleteConfirm(BankAccountDisplayModel account)
    {
        _deleteTarget = account;
        _statusMessage = null;
    }

    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;

        _isSaving = true;

        try
        {
            await BankAccountsApiClient.DeleteAsync(_deleteTarget.Id);
            _accounts.RemoveAll(a => a.Id == _deleteTarget.Id);
            _statusMessage = $"Account at {_deleteTarget.BankName} deleted.";
            _statusType = StatusType.Success;
            _deleteTarget = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete bank account {AccountId}", _deleteTarget?.Id);
            _statusMessage = $"Delete failed: {ex.Message}";
            _statusType = StatusType.Error;
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ── Label / CSS helpers ─────────────────────────────────────────────

    private static string AccountTypeLabel(BankAccountType type) => type switch
    {
        BankAccountType.Savings          => "Savings",
        BankAccountType.Current          => "Current",
        BankAccountType.FixedDeposit     => "Fixed Deposit",
        BankAccountType.RecurringDeposit => "Recurring Deposit",
        BankAccountType.Salary           => "Salary",
        BankAccountType.Other            => "Other",
        _                                => type.ToString()
    };

    /// <summary>Returns a stable CSS suffix for account-type badge colouring.</summary>
    private static string AccountTypeCss(BankAccountType type) => type switch
    {
        BankAccountType.Savings          => "savings",
        BankAccountType.Current          => "current",
        BankAccountType.FixedDeposit     => "fd",
        BankAccountType.RecurringDeposit => "rd",
        BankAccountType.Salary           => "salary",
        _                                => "other"
    };
}
