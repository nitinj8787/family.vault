@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<button class="vault-nav__hamburger" @onclick="ToggleMenu" aria-expanded="@_menuOpen"
        aria-controls="vault-nav-menu" aria-label="Toggle navigation">
    <span></span><span></span><span></span>
</button>

@if (_menuOpen)
{
    <div class="vault-nav__backdrop" @onclick="CloseMenu" aria-hidden="true"></div>
}

<nav class="vault-nav @(_menuOpen ? "vault-nav--open" : "")" id="vault-nav-menu"
     aria-label="Main navigation">
    <div class="vault-nav__brand">
        <span class="vault-nav__icon" aria-hidden="true">🔒</span>
        <span class="vault-nav__title">Family Vault</span>
        <button class="vault-nav__close" @onclick="CloseMenu" aria-label="Close navigation">✕</button>
    </div>

    <ul class="vault-nav__links" role="list">
        <li>
            <NavLink href="/" Match="NavLinkMatch.All" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🏠</span> Dashboard
            </NavLink>
        </li>
        <li>
            <NavLink href="/documents" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">📁</span> My Documents
            </NavLink>
        </li>
        <li>
            <NavLink href="/upload" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">⬆️</span> Upload
            </NavLink>
        </li>
        <li>
            <NavLink href="/profile" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">👤</span> My Profile
            </NavLink>
        </li>
        <li>
            <NavLink href="/uk-assets" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🏦</span> UK Assets
            </NavLink>
        </li>
        <li>
            <NavLink href="/india-assets" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🇮🇳</span> India Assets
            </NavLink>
        </li>
        <li>
            <NavLink href="/bank-accounts" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🏛</span> Bank Accounts
            </NavLink>
        </li>
        <li>
            <NavLink href="/investments" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">📈</span> Investments
            </NavLink>
        </li>
        <li>
            <NavLink href="/insurance" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🛡️</span> Insurance
            </NavLink>
        </li>
        <li>
            <NavLink href="/properties" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🏠</span> Property &amp; Loans
            </NavLink>
        </li>
        <li>
            <NavLink href="/emergency-fund" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🚨</span> Emergency Fund
            </NavLink>
        </li>
        <li>
            <NavLink href="/emergency" class="vault-nav__link vault-nav__link--emergency" @onclick="CloseMenu">
                <span aria-hidden="true">🆘</span> Emergency Mode
            </NavLink>
        </li>
        <li>
            <NavLink href="/nominees" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🧾</span> Nominees
            </NavLink>
        </li>
        <li>
            <NavLink href="/tax-summary" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">🧮</span> Tax Summary
            </NavLink>
        </li>
        <li>
            <NavLink href="/wills-legal" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">⚖️</span> Wills &amp; Legal
            </NavLink>
        </li>
        <li>
            <NavLink href="/about" class="vault-nav__link" @onclick="CloseMenu">
                <span aria-hidden="true">ℹ️</span> About
            </NavLink>
        </li>
    </ul>

    <div class="vault-nav__footer">
        <AuthorizeView>
            <Authorized>
                <span class="vault-nav__user">@context.User.Identity?.Name</span>
                <a href="MicrosoftIdentity/Account/SignOut" class="vault-nav__signout">Sign out</a>
            </Authorized>
            <NotAuthorized>
                <a href="MicrosoftIdentity/Account/SignIn" class="vault-nav__signout">Sign in</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private bool _menuOpen;

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;
}
