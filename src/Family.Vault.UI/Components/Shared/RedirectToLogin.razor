@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        // Force a full-page navigation to the Microsoft Identity sign-in endpoint so
        // that the OIDC redirect flow can proceed. The current URL is passed as the
        // post-login redirect target.
        var returnUrl = Uri.EscapeDataString(Navigation.Uri);
        Navigation.NavigateTo(
            $"MicrosoftIdentity/Account/SignIn?redirectUri={returnUrl}",
            forceLoad: true);
    }
}
