@inject IConfiguration Configuration

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            @if (UseAzureAdAuth)
            {
                <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                    <NotAuthorized>
                        @if (!context.User.Identity!.IsAuthenticated)
                        {
                            <RedirectToLogin />
                        }
                        else
                        {
                            <LayoutView Layout="typeof(Layout.MainLayout)">
                                <div class="vault-alert vault-alert--error" role="alert">
                                    You are not authorized to view this page.
                                </div>
                            </LayoutView>
                        }
                    </NotAuthorized>
                    <Authorizing>
                        <LayoutView Layout="typeof(Layout.MainLayout)">
                            <p>Verifying access…</p>
                        </LayoutView>
                    </Authorizing>
                </AuthorizeRouteView>
            }
            else
            {
                <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            }
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found – Family Vault</PageTitle>
            <LayoutView Layout="typeof(Layout.MainLayout)">
                <h1>Page not found</h1>
                <p>There is nothing at this address. <a href="/">Return home</a>.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private bool UseAzureAdAuth => Configuration.GetValue<bool>("VaultApi:UseAzureAdAuth");
}
